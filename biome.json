{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 1048576,
    "includes": [
      "**",
      "!packages/app-core/src/styles/**"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedPrivateClassMembers": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noImplicitAnyLet": "warn",
        "useIterableCallbackReturn": "warn",
        "noAssignInExpressions": "warn",
        "useAdjacentOverloadSignatures": "warn"
      },
      "complexity": {
        "noBannedTypes": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/training/src/benchmark/BenchmarkRunner.ts",
        "packages/training/src/benchmark/MetricsVisualizer.ts",
        "packages/training/src/benchmark/ModelBenchmarkService.ts",
        "packages/training/src/training/ModelUsageVerifier.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noStaticOnlyClass": "off"
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  }
}
