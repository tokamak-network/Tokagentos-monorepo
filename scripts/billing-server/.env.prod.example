# .env.prod.example — production secrets template for tokagent-billing-server
#
# HOW TO USE:
#   1. cp tokagentos/scripts/billing-server/.env.prod.example tokagentos/scripts/billing-server/.env.prod
#   2. Fill in every blank value below (search for "<fill-in>")
#   3. bash tokagentos/scripts/billing-server/setup-secrets.sh
#
# WARNING: Never commit .env.prod to git. It is in .gitignore.
# This .env.prod.example file (with blank values) IS committed — that is safe.
#
# WHAT GOES HERE vs apps/billing-server/fly.toml:
#   This file = secrets (keys, passwords, DSNs).
#   fly.toml [env] = non-secret config (addresses, feature flags, numeric params).
#   setup-secrets.sh reads THIS file and pushes each value to Fly secrets.
#   fly.toml is committed to git; .env.prod is not.
#
# Cross-checked against tokagentos/packages/billing/src/config.ts:
# every variable below is one the billing plugin actually reads.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────

# Postgres connection string. Any Postgres 14+ works (Supabase, Railway,
# AWS RDS, your own server, or any managed Postgres provider). If your
# provider offers a pooled connection endpoint (recommended for serverless
# / many-machine deployments), use that — it caps the number of upstream
# connections and avoids exhausting the database's connection limit under
# production load.
#
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>?sslmode=require
BILLING_DATABASE_URL=<fill-in>

# ── Authentication ───────────────────────────────────────────────────────────

# 32-byte random hex string used for both JWT HS256 signing AND HMAC of
# sk-ai-* API keys.
# Generation: openssl rand -hex 32
#
# RISK R-1: If this leaks, an attacker can forge JWTs for ANY wallet and
# drain their deposited credits. Rotate immediately on any suspected leak:
#   flyctl secrets set BILLING_AUTH_SECRET=$(openssl rand -hex 32) --app tokagent-billing-server
# All in-flight sessions are invalidated immediately on rotation — users
# must re-authenticate (SIWE login). Blast radius: every wallet with deposits.
BILLING_AUTH_SECRET=<fill-in>

# ── Operator key (on-chain credit consumption) ───────────────────────────────

# EOA private key (0x-prefixed 32-byte hex) that calls vault.consumeCredits()
# and vault.depositX402() on mainnet.
#
# Generation: cast wallet new | grep "Private Key"
# The EOA MUST hold ~0.1 ETH for gas. Keep balance near this ceiling — a
# compromised key can only drain ~50 consume txs before running out.
#
# RISK R-3 (Critical): This key gates real on-chain money. Mitigations:
#   • Weekly rotation (see docs/billing-server-DEPLOY.md § Operator key rotation).
#   • Balance ceiling ~0.1 ETH.
#   • Phase-2: migrate to AWS KMS / Gnosis Safe multisig.
#
# Rotation runbook: derive new EOA → fund with 0.1 ETH → transfer OPERATOR
# role on ClaudeVault to the new EOA via admin multisig →
#   flyctl secrets set BILLING_OPERATOR_PRIVATE_KEY=0x<new-key> --app tokagent-billing-server
BILLING_OPERATOR_PRIVATE_KEY=<fill-in>

# ── RPC endpoints ────────────────────────────────────────────────────────────

# Mainnet RPC used for vault writes (consumeCredits, depositX402 txs).
# Must support eth_sendRawTransaction and eth_getTransactionReceipt.
# Providers: Alchemy (recommended), Infura, QuickNode.
# Format: https://eth-mainnet.g.alchemy.com/v2/<YOUR-KEY>
BILLING_CHAIN_RPC_URL=<fill-in>

# Mainnet RPC used for TWAP reads (Uniswap V3 observe() calls).
# Can be the same provider as BILLING_CHAIN_RPC_URL — different endpoint
# is fine too. Needs eth_call support. Does NOT need eth_sendRawTransaction.
BILLING_MAINNET_RPC_URL=<fill-in>

# ── LiteLLM backend ──────────────────────────────────────────────────────────

# API key for the LiteLLM backend at https://api.ai.tokamak.network/
# This is the key the billing server uses to authenticate outbound inference
# requests on behalf of all x402 clients.
# Obtain from the LiteLLM admin (or your own LiteLLM deployment).
BILLING_LITELLM_API_KEY=<fill-in>

# ─────────────────────────────────────────────────────────────────────────────
# NON-SECRET CONFIG (these live in apps/billing-server/fly.toml [env])
# Listed here for reference only — do NOT duplicate them in this file.
# ─────────────────────────────────────────────────────────────────────────────
#
# BILLING_MODE                = "server"
# BILLING_ENABLED             = "true"
# BILLING_AUTH_REQUIRED       = "true"
# BILLING_CHAIN_ID            = "1"
# BILLING_VAULT_ADDRESS       = "0x1072f70e7c490E460fA72AC4171F7aDD1ef2d79F"
# BILLING_PTON_ADDRESS        = "0x00D1EDcE8E7c617891FF76224DFf501c568f1Ce0"
# BILLING_WTON_WETH_POOL_ADDRESS, BILLING_WETH_USDC_POOL_ADDRESS, decimal flags
# BILLING_LITELLM_BASE_URL    = "https://api.ai.tokamak.network/"
# BILLING_MARGIN_BPS          = "100"
# BILLING_MARGIN_FLOOR_BPS    = "50"
# BILLING_PROMOTION_DISCOUNT_BPS = "0"
# BILLING_RATE_LIMIT_*        (see fly.toml)
# BILLING_CONSUME_*           (see fly.toml)
# BILLING_USAGE_*             (see fly.toml)
# TOKAGENT_PORT               = "8080"
# NODE_ENV                    = "production"
# LOG_LEVEL                   = "info"
