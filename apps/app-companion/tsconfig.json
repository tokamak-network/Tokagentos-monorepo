{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types",
      "../../../node_modules",
      "../../../node_modules/.bun/node_modules"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": "../../",
    "paths": {
      "@elizaos/app-lifeops": ["./apps/app-lifeops/src/index.ts"],
      "@elizaos/app-lifeops/*": ["./apps/app-lifeops/src/*"],
      "@elizaos/app-task-coordinator": ["./apps/app-task-coordinator/src/index.ts"],
      "@elizaos/app-task-coordinator/*": ["./apps/app-task-coordinator/src/*"],
      "@elizaos/app-steward": ["./apps/app-steward/src/index.ts"],
      "@elizaos/app-steward/*": ["./apps/app-steward/src/*"],
      "@elizaos/app-core": ["./packages/app-core/src/index.ts"],
      "@elizaos/app-core/*": ["./packages/app-core/src/*"],
      "@elizaos/ui": ["./packages/ui/src/index.ts"],
      "@elizaos/ui/*": ["./packages/ui/src/*"],
      "@elizaos/app-companion": ["./apps/app-companion/src/index.ts"],
      "@elizaos/app-companion/*": ["./apps/app-companion/src/*"],
      "@elizaos/core": ["./packages/typescript/src/index.ts"],
      "@elizaos/core/*": ["./packages/typescript/src/*"],
      "@elizaos/agent": ["./packages/agent/src/index.ts"],
      "@elizaos/agent/*": ["./packages/agent/src/*"],
      "@elizaos/shared": ["./packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["./packages/shared/src/*"],
      "react": ["./packages/app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "./packages/app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "./packages/app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "./packages/app-core/node_modules/@types/react-dom/index.d.ts"
      ],
      "@elizaos/*": ["./node_modules/@elizaos/*"],
      "lucide-react": ["./apps/app-companion/node_modules/lucide-react"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../packages/agent/src/external-modules.d.ts",
    "../../packages/app-core/src/ambient-modules.d.ts"
  ],
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
