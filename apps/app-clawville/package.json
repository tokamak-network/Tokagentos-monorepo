{
  "name": "@clawville/app-clawville",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Eliza app integration for ClawVille — sea-themed agent game where any connected agent can enter a 3D underwater world, visit 10 specialist buildings, and learn skills via the agentskills.io open standard. Auto-generates a custodial Solana wallet per Eliza agent on first launch.",
  "main": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./routes": "./src/routes.ts"
  },
  "homepage": "https://clawville.world/",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza.git"
  },
  "keywords": [
    "game",
    "agents",
    "clawville",
    "sea",
    "openclaw",
    "skills",
    "solana",
    "elizaos",
    "eliza"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*"
  },
  "elizaos": {
    "kind": "app",
    "app": {
      "displayName": "ClawVille",
      "category": "game",
    "heroImage": "assets/hero.png",
      "launchType": "connect",
      "launchUrl": "https://clawville.world/game",
      "capabilities": [
        "game",
        "skill-learning",
        "tokens",
        "multi-agent",
        "solana-wallet"
      ],
      "runtimePlugin": "@clawville/app-clawville",
      "viewer": {
        "url": "/api/apps/clawville/viewer",
        "sandbox": "allow-scripts allow-same-origin allow-popups allow-forms"
      },
      "session": {
        "mode": "spectate-and-steer",
        "features": [
          "commands",
          "telemetry",
          "suggestions"
        ]
      }
    }
  }
}
