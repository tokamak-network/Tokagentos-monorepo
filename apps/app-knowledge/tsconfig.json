{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@tokagentos/core": ["../../packages/typescript/src/index.node.ts"],
      "@tokagentos/core/*": ["../../packages/typescript/src/*"],
      "@tokagentos/agent": ["../../packages/agent/src/index.ts"],
      "@tokagentos/agent/*": ["../../packages/agent/src/*"],
      "@tokagentos/shared": ["../../packages/shared/src/index.ts"],
      "@tokagentos/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
