{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["@tokagentos/core#build", "^build"],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"]
    },
    "@tokagentos/agent#build": {
      "dependsOn": ["@tokagentos/core#build", "@tokagentos/shared#build"],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"]
    },
    "@tokagentos/app-core#build": {
      "dependsOn": ["@tokagentos/core#build", "@tokagentos/agent#build", "@tokagentos/shared#build"],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"]
    },
    "@tokagentos/core#build": {
      "dependsOn": [],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "build.ts", "tsconfig.declarations.json"]
    },
    "@tokagentos/client#build": {
      "dependsOn": ["^build"],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"]
    },
    "@tokagentos/server#build": {
      "dependsOn": ["@tokagentos/client#build", "^build"],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"]
    },
    "@elizaos/plugin-discord-root#build": {
      "outputs": []
    },
    "@elizaos/plugin-groq-root#build": {
      "outputs": []
    },
    "@elizaos/plugin-imessage-root#build": {
      "outputs": []
    },
    "@elizaos/plugin-local-ai-root#build": {
      "outputs": []
    },
    "@elizaos/plugin-ollama-root#build": {
      "outputs": []
    },
    "@elizaos/plugin-openai-root#build": {
      "outputs": []
    },
    "@elizaos/plugin-openrouter-root#build": {
      "outputs": []
    },
    "@elizaos/plugin-sql-root#build": {
      "outputs": []
    },
    "@tokagentos/schemas#build": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["@tokagentos/core#build"],
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "start": {
      "dependsOn": ["@tokagentos/core#build"],
      "env": ["LOG_LEVEL"],
      "persistent": true
    },
    "dev": {
      "dependsOn": ["@tokagentos/core#build"],
      "persistent": true
    },
    "test": {
      "dependsOn": [],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "src/**/*.js", "__tests__/**/*", "*.test.*", "package.json", "tests/**/*"],
      "cache": false
    },
    "migrate": {
      "dependsOn": ["@tokagentos/core#build"],
      "cache": false
    },
    "migrate:generate": {
      "dependsOn": ["@tokagentos/core#build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
