{
  "name": "@elizaos/plugin-executecode",
  "version": "2.0.0-alpha.176",
  "description": "Run a JS/TS-style script that calls multiple agent actions sequentially through an in-process tools proxy.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza.git"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eliza",
    "plugin",
    "execute-code",
    "tool-use",
    "agent"
  ],
  "author": "elizaOS",
  "license": "MIT",
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --hot build.ts",
    "clean": "rm -rf dist .turbo node_modules",
    "test": "vitest run",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "lint": "echo \"Lint skipped\"",
    "lint:check": "bun run lint",
    "check": "bun run typecheck && bun run test"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "EXECUTECODE_TIMEOUT_MS": {
        "type": "number",
        "description": "Default timeout for executeCode scripts in milliseconds.",
        "required": false,
        "default": 30000,
        "sensitive": false
      },
      "EXECUTECODE_DISABLE": {
        "type": "boolean",
        "description": "Set to disable the executeCode action even when the plugin is loaded.",
        "required": false,
        "default": false,
        "sensitive": false
      }
    }
  },
  "milady": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "Default export (Node.js)"
    }
  }
}
