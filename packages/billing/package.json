{
  "name": "@tokagentos/billing",
  "version": "0.1.0",
  "description": "Web3 credit-billing rail for tokagentos. Migrated from llm-api-gateway.",
  "type": "module",
  "publishConfig": { "access": "public", "directory": "dist" },
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./chain/addresses": "./src/chain/addresses.ts"
  },
  "files": ["src", "README.md", "LICENSE"],
  "scripts": {
    "build": "bun run build.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "sync-abis": "./scripts/sync-abis.sh",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "viem": "^2.21.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@tokagentos/core": "workspace:*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@tokagentos/core": "workspace:*",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
