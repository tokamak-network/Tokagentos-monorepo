{
  "name": "@tokagentos/billing",
  "version": "2.0.0",
  "description": "Pure-compute helpers for the tokagentos CLI: token estimation, model pricing, TWAP oracle, EIP-712/EIP-3009 typed-data builders, SIWE verifier. The ledger and chain writes live in the hosted gateway.",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./chain/addresses": "./src/chain/addresses.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "sync-abis": "./scripts/sync-abis.sh",
    "probe-twap": "bun run scripts/probe-twap.ts"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "viem": "^2.21.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@tokagentos/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
