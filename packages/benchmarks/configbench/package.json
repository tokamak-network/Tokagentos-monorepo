{
  "name": "@elizaos/configbench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Configuration & Secrets Security Benchmark for TokagentOS plugin-secrets-manager and plugin-plugin-manager",
  "main": "src/index.ts",
  "scripts": {
    "bench": "bun run src/index.ts",
    "bench:tokagent": "bun run src/index.ts --tokagent",
    "bench:all": "bun run src/index.ts --tokagent --all",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tokagentos/core": "alpha"
  },
  "devDependencies": {
    "vitest": "3.1.4",
    "typescript": "6.0.3"
  }
}
