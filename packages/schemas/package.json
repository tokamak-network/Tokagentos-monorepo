{
  "name": "@tokagentos/schemas",
  "version": "2.0.0-alpha.274",
  "description": "Protocol Buffer schemas for tokagentOS - single source of truth for all types",
  "files": [
    "tokagent",
    "buf.yaml",
    "buf.gen.yaml",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "buf lint",
    "format": "buf format -w",
    "breaking": "buf breaking --against '.git#branch=main'",
    "generate": "buf generate",
    "generate:ts": "buf generate --template buf.gen.ts.yaml",
    "generate:py": "buf generate --template buf.gen.py.yaml",
    "generate:rs": "buf generate --template buf.gen.rs.yaml",
    "clean": "rm -rf ../typescript/src/types/generated ../python/tokagentos/types/generated ../rust/src/types/generated",
    "build": "npm run lint && npm run generate",
    "test": "buf lint"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.47.2"
  },
  "gitHead": "95112b35f869c31e3b93899b9f60716c288785a6"
}
