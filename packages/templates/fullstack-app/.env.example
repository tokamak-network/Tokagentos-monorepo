# ============================================================================
# Tokagent agent configuration
# ============================================================================
# Copy this file to `.env` (or let `tokagentos create` scaffold it for you) and
# fill in the placeholders. Most values have safe defaults; you only HAVE to
# set the items flagged REQUIRED. The rest can stay commented until you need
# them.

# ── REQUIRED: LLM provider ──────────────────────────────────────────────────
# Set by `tokagentos create --llm <provider> --api-key <key>`. Pick ONE that
# matches your selected provider. Leave the others unset.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# ── Execution mode ──────────────────────────────────────────────────────────
# Controls which plugin set loads at agent boot:
#   "vault"  (default) — TokagentVault custody. Writes go through the vault's
#                        allowlist. plugin-evm is NOT loaded.
#   "direct"           — plugin-evm signs directly from the hot wallet.
#                        Tokagent yield/perps/polymarket plugins NOT loaded.
#   "both"             — everything loaded. LLM picks per request. Less safe.
TOKAGENT_EXECUTION_MODE=vault

# ── REQUIRED for on-chain actions: operator hot wallet ──────────────────────
# 32-byte hex, 0x-prefixed. Generate with:  cast wallet new
# This key signs:
#   • factory.deployTokagentVault() when you ask the agent to create a vault
#   • vault.executeBatch() for Tokagent vault writes (yield/perps/polymarket)
#   • plugin-evm transactions in "direct" mode
# Fund the derived address with a small amount of gas on whichever chain you
# target: ~0.5 MATIC / ~0.005 ETH / ~0.01 HYPE.
# TOKAGENT_PRIVATE_KEY=0x...

# Optional: if you want plugin-evm to sign with a DIFFERENT key than the
# Tokagent operator. Most setups leave this unset and plugin-evm falls back
# to TOKAGENT_PRIVATE_KEY.
# EVM_PRIVATE_KEY=0x...

# ── Vault addresses (set after deploying a vault) ───────────────────────────
# The Tokagent plugins read these to know which vault to operate on per chain.
# Leave unset = "no vault configured for this chain" and writes error clearly.
# Populate after calling DEPLOY_TOKAGENT_VAULT from chat (or `tal deploy
# --kind tokagent`).
# TOKAGENT_VAULT_ADDRESS_1=0x...      # Ethereum mainnet
# TOKAGENT_VAULT_ADDRESS_137=0x...    # Polygon
# TOKAGENT_VAULT_ADDRESS_999=0x...    # HyperEVM

# ── RPC overrides (optional — defaults to public RPCs) ──────────────────────
# Used by Tokagent plugins for reads + tx submission.
# POLYGON_RPC_URL=https://polygon-bor.publicnode.com
# RPC_URL_MAINNET=https://ethereum-rpc.publicnode.com
# RPC_URL_HYPER_MAINNET=https://rpc.hyperliquid.xyz/evm

# Used by plugin-evm (direct mode only).
# EVM_PROVIDER_MAINNET=https://ethereum-rpc.publicnode.com
# EVM_PROVIDER_POLYGON=https://polygon-bor.publicnode.com
# EVM_RPC_PROVIDER=public   # or "alchemy" / "infura" if you have a key

# ── External API endpoints (optional — defaults work) ───────────────────────
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# POLYMARKET_DATA_URL=https://data-api.polymarket.com

# ── Strategy engine persistence ─────────────────────────────────────────────
# Where strategies.json is stored. Defaults to $HOME/.tokagent.
# TOKAGENT_DATA_DIR=/some/custom/path

# ── Hyperliquid perps prerequisites (optional, reminders) ───────────────────
# Before the perp-funding-arb strategy can execute:
#   1. Send HYPE to the vault address on HyperEVM (covers CoreWriter gas)
#   2. Register an API wallet with the vault address on Hyperliquid's UI
#   3. Seed the first perp trade via Hyperliquid REST (HyperCore rejects
#      orders with leverage=0 and CoreWriter has no updateLeverage action)
# These are out-of-band setup steps — no env vars, just prerequisites.

# ── Eliza runtime ports (optional) ──────────────────────────────────────────
# ELIZA_API_PORT=31337
# TOKAGENT_PORT=2138
