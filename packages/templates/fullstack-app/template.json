{
  "id": "fullstack-app",
  "name": "fullstack-app",
  "description": "Create a Milady-style fullstack app workspace backed by a local tokagent checkout",
  "kind": "fullstack-app",
  "version": 1,
  "languages": ["typescript"],
  "upstream": {
    "path": "tokagent",
    "repo": "https://github.com/tokagentos/tokagent.git",
    "branch": "develop",
    "mode": "git-submodule",
    "requiredSubmodules": [
      "plugins/plugin-local-ai",
      "plugins/plugin-ollama",
      "plugins/plugin-sql",
      "plugins/plugin-tokagentcloud"
    ],
    "requiredWorkspaces": [
      "plugins/plugin-local-ai/typescript",
      "plugins/plugin-ollama/typescript",
      "plugins/plugin-sql/typescript",
      "plugins/plugin-tokagentcloud/typescript"
    ]
  }
}
