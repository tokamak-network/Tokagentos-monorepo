{
  "name": "@tokagentos/scenario-runner",
  "version": "2.0.0-alpha.223",
  "description": "Lean scenario runner for the WS7 scenario-schema architecture. Loads .scenario.ts files, executes them against a real @tokagentos/core AgentRuntime with a live LLM, and emits a JSON report.",
  "type": "module",
  "main": "./src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "milady-scenarios": "./bin/milady-scenarios"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tokagentos/core": "workspace:*",
    "@tokagentos/plugin-sql": "workspace:*",
    "@tokagentos/scenario-schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
