{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun-types"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types",
      "../../node_modules",
      "../../../node_modules",
      "../../../node_modules/.bun/node_modules"
    ],
    "allowImportingTsExtensions": true,
    "declaration": false,
    "noEmit": true,
    "baseUrl": "../../",
    "paths": {
      "@tokagentos/app-lifeops": ["./apps/app-lifeops/src/index.ts"],
      "@tokagentos/app-lifeops/*": ["./apps/app-lifeops/src/*"],
      "@tokagentos/app-tokagentmaker": ["./apps/app-tokagentmaker/src/index.ts"],
      "@tokagentos/app-tokagentmaker/*": ["./apps/app-tokagentmaker/src/*"],
      "@tokagentos/app-task-coordinator": ["./apps/app-task-coordinator/src/index.ts"],
      "@tokagentos/app-task-coordinator/*": ["./apps/app-task-coordinator/src/*"],
      "@tokagentos/app-steward": ["./apps/app-steward/src/index.ts"],
      "@tokagentos/app-steward/*": ["./apps/app-steward/src/*"],
      "@tokagentos/app-shopify": ["./apps/app-shopify/src/index.ts"],
      "@tokagentos/app-shopify/*": ["./apps/app-shopify/src/*"],
      "@tokagentos/app-training": ["./apps/app-training/src/index.ts"],
      "@tokagentos/app-training/*": ["./apps/app-training/src/*"],
      "@tokagentos/app-vincent": ["./apps/app-vincent/src/index.ts"],
      "@tokagentos/app-vincent/*": ["./apps/app-vincent/src/*"],
      "@elizaos/plugin-lifeops-browser": [
        "./plugins/plugin-lifeops-browser/src/index.ts"
      ],
      "@elizaos/plugin-lifeops-browser/*": [
        "./plugins/plugin-lifeops-browser/src/*"
      ],
      "@tokagentos/app-core": ["./packages/app-core/src/index.ts"],
      "@tokagentos/app-core/*": ["./packages/app-core/src/*"],
      "@tokagentos/ui": ["./packages/ui/src/index.ts"],
      "@tokagentos/ui/*": ["./packages/ui/src/*"],
      "@tokagentos/agent": ["./packages/agent/src/index.ts"],
      "@tokagentos/agent/*": ["./packages/agent/src/*"],
      "@tokagentos/app-companion": ["./apps/app-companion/src/index.ts"],
      "@tokagentos/app-companion/*": ["./apps/app-companion/src/*"],
      "@tokagentos/shared": ["./packages/shared/src/index.ts"],
      "@tokagentos/shared/*": ["./packages/shared/src/*"],
      "@tokagentos/skills": ["./packages/skills/src/index.ts"],
      "@tokagentos/skills/*": ["./packages/skills/src/*"],
      "@tokagentos/core": ["./packages/typescript/src/index.ts"],
      "@tokagentos/core/*": ["./packages/typescript/src/*"],
      "@tokagentos/native-activity-tracker": [
        "./packages/native-plugins/activity-tracker/src/index.ts"
      ],
      "react": ["./packages/app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "./packages/app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "./packages/app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "./packages/app-core/node_modules/@types/react-dom/index.d.ts"
      ],
      "@tokagentos/*": ["./node_modules/@tokagentos/*"],
      "lucide-react": ["./packages/app-core/node_modules/lucide-react"]
    }
  },
  "exclude": [
    "src/cli/**",
    "src/benchmark/**",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "../../apps/app-companion/src/**/*.stories.ts",
    "../../apps/app-companion/src/**/*.stories.tsx",
    "../../apps/app-companion/src/**/*.test.ts",
    "../../apps/app-companion/src/**/*.test.tsx"
  ],
  "include": [
    "src",
    "../agent/src/external-modules.d.ts",
    "../../apps/app-companion/src",
    "vite-env.d.ts"
  ]
}
