# Cloud-specific dockerignore for tokagent/packages/app-core/deploy/Dockerfile.cloud
# The cloud build does a fresh `bun install --production` in the deps stage,
# so we exclude the host node_modules entirely (they'd bloat the build context ~4.5GB).
# Only the manifests, lockfile, patches, pre-built dist artifacts, workspace source
# packages, and runtime scripts are needed.

.git
.github
.claude
.devin
.vscode
.idea
.env
.env.local
.env.*.local

# Exclude ALL node_modules from build context — deps stage reinstalls from scratch
node_modules/
packages/**/node_modules
apps/**/node_modules
tokagent/**/node_modules
tokagent/packages/app-core/deploy/**/node_modules
tokagent/.turbo
tokagent/packages/rust
tokagent/packages/python
tokagent/packages/benchmarks
tokagent/packages/examples
tokagent/apps
tokagent/cloud
tokagent/plugins/*/rust
tokagent/plugins/*/python
tokagent/plugins/*/.git
tokagent/plugins/*/.tokagent
tokagent/plugins/*/.tokagentdb-test

# Exclude heavy app dirs not needed at runtime
# (but keep package.json manifests that the deps stage needs for bun install)
apps/app/android
apps/app/electrobun
!apps/app/electrobun/package.json
apps/app/.vite
apps/app/src
apps/app/public
apps/app/test
apps/app/.tokagent
apps/web/
!apps/web/package.json
apps/homepage
apps/home
apps/landing
apps/chrome-extension
apps/ui

# Test / tooling / packaging / docs
docs/
coverage/
benchmarks/
test/
skills/
packaging/
artifacts/
dev.log
install.sh
install.ps1
deploy/

# Other deploy Docker recipes — cloud image build only needs Dockerfile.cloud
tokagent/packages/app-core/deploy/Dockerfile.ci
tokagent/packages/app-core/deploy/Dockerfile.cloud-agent
tokagent/packages/app-core/deploy/Dockerfile.sandbox
!tokagent/packages/app-core/deploy/Dockerfile.cloud
