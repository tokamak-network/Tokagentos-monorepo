# Default deployment configuration for tokagentOS apps.

APP_NAME=tokagent
APP_ENTRYPOINT=app.mjs
APP_CMD_START="node --import ./node_modules/tsx/dist/loader.mjs app.mjs start"
APP_IMAGE=tokagent:local
APP_REGISTRY=
APP_PORT=2138
APP_GATEWAY_PORT=18789
APP_BRIDGE_PORT=18790
APP_GATEWAY_BIND=lan
APP_STATE_DIR=/home/node/.tokagent
APP_CONFIG_DIR="${HOME}/.tokagent"
APP_WORKSPACE_DIR="${HOME}/.tokagent/workspace"
APP_DB_NAME=tokagent
APP_API_BIND=127.0.0.1
OCI_SOURCE=""
OCI_TITLE="tokagentOS Agent"
OCI_DESCRIPTION="tokagentOS agent runtime"
OCI_LICENSES=MIT
CF_WORKER_NAME=tokagent-cloud-proxy
CF_ALLOWED_ORIGINS=
CF_PROXY_PATH_PREFIXES=
