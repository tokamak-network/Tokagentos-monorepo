#!/bin/sh
set -e

case "$1" in
    configure)
        # Install systemd user service
        if [ -d /usr/lib/systemd/user ]; then
            cp /usr/lib/tokagentos-app/tokagentos-app.service /usr/lib/systemd/user/tokagentos-app.service 2>/dev/null || true
            systemctl --global daemon-reload 2>/dev/null || true
        fi

        echo ""
        echo "  tokagentOS App installed! Get started:"
        echo ""
        echo "    tokagentos-app start            — Start interactively"
        echo "    tokagentos-app setup            — Initialize workspace"
        echo "    tokagentos-app --help           — Show all commands"
        echo ""
        echo "  To run as a background service:"
        echo ""
        echo "    systemctl --user enable --now tokagentos-app"
        echo ""
        ;;
esac

#DEBHELPER#

exit 0
