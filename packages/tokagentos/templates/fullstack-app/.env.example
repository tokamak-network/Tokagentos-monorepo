####################################
#### Execution Mode ####
####################################

# Required. How strategy actions get executed on-chain.
#   vault  — actions go through the Tokagent vault contract (default).
#            Loads tokagent vault plugins (yield/perps/polymarket).
#            plugin-evm is NOT loaded — chat cannot raw-sign EVM txs.
#   direct — agent signs transactions directly from the operator wallet.
#            Loads plugin-evm so chat-driven swaps/transfers work.
#            Vault plugins are NOT loaded.
#   both   — everything loaded; LLM picks per request. Less safe.
#
# If you want to drive trades from chat ("swap 1 USDC for ETH", etc.),
# pick `direct` or `both`. `vault` is the safe default for production.
TOKAGENT_EXECUTION_MODE=vault

####################################
#### Server ####
####################################

# Server port (operator mode only).
SERVER_PORT=3000

# Server host. Default: 0.0.0.0
SERVER_HOST=

# development | production. Affects UI availability and security defaults.
NODE_ENV=development

# Express max payload size (default 2mb).
EXPRESS_MAX_PAYLOAD=2mb

####################################
#### Database ####
####################################

# PostgreSQL URL. If unset, falls back to PGLite (local file/memory).
POSTGRES_URL=

# PGLite directory. Use memory:// for in-memory (dev only).
PGLITE_DATA_DIR=

####################################
#### AI Provider (pick at least one) ####
####################################

# Anthropic Claude API key. Always-on provider; required if no other provider set.
ANTHROPIC_API_KEY=

# Optional additional providers (auto-enabled when their key is present).
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# LiteLLM (OpenAI-compatible proxy). Set all four to route through a self-
# hosted or hosted LiteLLM proxy. When set, these override OPENAI_* at runtime;
# a tokagent boot warning is logged so the active backend is unambiguous.
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_SMALL_MODEL=
LITELLM_LARGE_MODEL=

# OpenRouter model overrides. plugin-openrouter's defaults route through
# google/gemini-2.0-flash-001 (small) and google/gemini-2.5-flash (large)
# — both Google free-tier on OpenRouter and frequently rate-limited (429)
# or upstream-aborted (504), which makes the chat slow (each LLM call
# burns ~20s in retry backoff). Override with stable Anthropic models —
# OpenRouter routes them reliably even without a paid Google key.
#
# Skip these if you have a Google key with paid quota and want to use
# Gemini Flash. Or pin to whichever model your account has best rates on.
# NOTE: OpenRouter uses dots in version suffixes (4.5, not 4-5). Bad model
# ids surface as AI_NoOutputGeneratedError because the upstream returns an
# error event the AI SDK stream parser cannot translate to a message.
# Verify against https://openrouter.ai/api/v1/models before changing these.
OPENROUTER_SMALL_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_LARGE_MODEL=anthropic/claude-sonnet-4.6

# Local LLM endpoints (optional).
OLLAMA_API_ENDPOINT=

####################################
#### Operator Wallet (required for signing) ####
####################################

# The hot wallet that signs all strategy transactions. 64 hex chars,
# 0x-prefixed. Generate a fresh test key with `cast wallet new` —
# never paste a mainnet key with significant balance into a workstation
# .env file. Real funds are at risk.
#
# Read by plugin-tokagent-shared via runtime.getSetting('TOKAGENT_PRIVATE_KEY').
# Auto-mirrored to EVM_PRIVATE_KEY at agent boot so the upstream wallet UI
# (/wallet page, chat wallet questions) can derive the same address from
# a single env entry.
#
# Alternative: leave this empty and use the /wallet page wizard's
# "Generate" or "Import" path to store the key in the OS keychain instead.
TOKAGENT_PRIVATE_KEY=

# EVM RPC endpoint for Ethereum mainnet. Used by the wallet UI to fetch
# balances and by chat wallet actions to read on-chain state.
#
# Auto-mirrored at agent boot to:
#   - EVM_PROVIDER_URL / ETHEREUM_PROVIDER_URL  → satisfies the agent's
#     `rpcReady` capability gate
#   - ETHEREUM_PROVIDER_MAINNET / EVM_PROVIDER_MAINNET  → feeds plugin-evm's
#     mainnet client, replacing viem's default eth.merkle.io (which is slow
#     and times out balance reads)
#
# For other chains (base, polygon, arbitrum, optimism, bsc…), set the
# per-chain env directly: ETHEREUM_PROVIDER_BASE, ETHEREUM_PROVIDER_POLYGON,
# ETHEREUM_PROVIDER_ARBITRUM, ETHEREUM_PROVIDER_OPTIMISM, BSC_RPC_URL, etc.
# TOKAGENT_RPC_URL only mirrors to mainnet.
#
# Example values:
#   https://eth.llamarpc.com         (free, public, Ethereum mainnet)
#   https://rpc.ankr.com/eth         (free, public, Ethereum mainnet)
#   https://ethereum.publicnode.com  (free, public, Ethereum mainnet)
#   https://mainnet.infura.io/v3/<your_project_id>
#   https://eth-mainnet.g.alchemy.com/v2/<your_api_key>
TOKAGENT_RPC_URL=

####################################
#### Tokagent Vault ####
####################################

# Deployed Tokagent vault address (per the chain your strategies target).
TOKAGENT_VAULT_ADDRESS=

# HyperEVM helper contract (stateless bridge + CoreWriter dispatcher).
# Mainnet default: 0x8350777738059f29f639e493ea96e20d2f58171c
TOKAGENT_HYPERLIQUID_HELPER_ADDRESS=

####################################
#### A2A + x402 client (plugin-a2a-client) ####
####################################
# CALL_A2A_AGENT action discovers and invokes other agents via Google's
# A2A protocol, paying with x402 vouchers (signed EIP-3009 PTON
# authorizations) when a peer returns 402 Payment Required.
#
# Wallet handling: the plugin signs vouchers with TOKAGENT_PRIVATE_KEY
# (the same operator key the vault plugins use). Without it, 402
# responses become a clear "no wallet configured" error — never a silent
# skip. The key is read in memory, never logged, never serialized into
# request bodies.

# Optional facilitator URL for off-band voucher verification. v0.1 trusts
# the upstream 2xx response after our X-Payment retry, so leave unset
# unless you specifically want a facilitator round-trip.
X402_FACILITATOR_URL=

# Hard cap on any single x402 payment, in PTON. The plugin refuses to
# sign vouchers above this amount and surfaces a clear error showing the
# request vs the cap. Raise here if you call expensive paid agents.
X402_MAX_PAYMENT_PER_CALL_PTON=1.0

# Session-cumulative spend cap, in PTON. Once exceeded, subsequent 402
# challenges emit X402_SESSION_CAP_HIT and are refused until the agent
# restarts or this cap is raised.
X402_MAX_TOTAL_SPEND_PTON=10.0

# Optional AgentCard registry — falls back to per-call GET
# /.well-known/agent.json when unset. No registry is required for v0.1.
A2A_REGISTRY_URL=

####################################
#### RPC Endpoints & External APIs (optional overrides) ####
####################################

# Polygon RPC override (for Aave yield plugin).
POLYGON_RPC_URL=

# Hyperliquid API base URL (default: https://api.hyperliquid.xyz).
HYPERLIQUID_API_URL=

# Polymarket endpoints (defaults: public Gamma/data-api URLs).
POLYMARKET_DATA_URL=
POLYMARKET_GAMMA_URL=

####################################
#### Optional Messaging Channels ####
####################################

# Each channel is auto-enabled when its credentials are present.
# Prefer setting these via the Settings → Channels UI — it validates the
# token against the platform's API and triggers an agent restart so the
# bot comes online immediately. Setting the env var here works too, but
# requires a manual `bun run dev` restart.
#
# Telegram: paste the BotFather token. Plugin: @elizaos/plugin-telegram.
#
# Two reply-gating env vars also need to be set or the bot ingests
# messages into memory but never responds (both silent skips, debug-
# level only):
#
#   TELEGRAM_AUTO_REPLY=true
#     Without this the plugin's handleMessage early-returns.
#
#   LIFEOPS_PASSIVE_CONNECTORS=false
#     Default is "enabled" — when enabled, lifeOps owns connector
#     replies and the agent's main LLM pipeline is bypassed. Set to
#     false so the regular chat path handles Telegram replies.
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTO_REPLY=true
LIFEOPS_PASSIVE_CONNECTORS=false
#
# Discord: paste the bot token from the Developer Portal → Bot → Token.
# The upstream plugin reads DISCORD_API_TOKEN; DISCORD_BOT_TOKEN is also
# accepted (auto-mirrored at boot in core-plugins.ts). Plugin: @elizaos/plugin-discord.
DISCORD_BOT_TOKEN=
#
# X / Twitter: all FOUR keys are required for the plugin to load
# (consumer key + secret, OAuth1 access token + secret). The upstream
# plugin reads X_*; the TWITTER_* names below are accepted via boot-time
# aliasing. Plugin: @elizaos/plugin-x.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
#
# WhatsApp: NO API token. The plugin uses a QR-code pairing flow via
# Baileys — set WHATSAPP_AUTH_DIR to a writable directory and complete
# pairing through Settings → Channels → WhatsApp. The legacy
# WHATSAPP_ACCESS_TOKEN var is ignored.
WHATSAPP_AUTH_DIR=
#
# Signal: NO phone-number-only flow. The plugin talks to a signal-cli
# bridge — set SIGNAL_HTTP_URL to the bridge endpoint and
# SIGNAL_ACCOUNT_NUMBER to the registered phone. SIGNAL_PHONE_NUMBER
# alone does nothing.
SIGNAL_HTTP_URL=
SIGNAL_ACCOUNT_NUMBER=

####################################
#### Runtime Tunables (optional) ####
####################################

# Total timeout for parallel providers, in ms (default 1000).
PROVIDERS_TOTAL_TIMEOUT_MS=1000

# Non-interactive CLI mode.
TOKAGENT_NONINTERACTIVE=

# Character URLs (comma-separated).
REMOTE_CHARACTER_URLS=

####################################
#### Data Directories (optional) ####
####################################

# TOKAGENT_DATA_DIR=.tokagent
# TOKAGENT_DATABASE_DIR=
# TOKAGENT_DATA_DIR_CHARACTERS=
# TOKAGENT_DATA_DIR_GENERATED=

#########################################
#### x402 Billing (plugin-tokagent-billing)
####
#### DEFAULT: client-mode pointing at the Tokamak-hosted billing rail
#### (https://billing-service-production-a8e7.up.railway.app). No setup
#### required — open the agent UI's x402 page, connect your wallet, deposit
#### PTON, and start making billed LLM calls. The hosted server owns the
#### Postgres + on-chain operator EOA on your behalf.
####
#### Two ways to use billing:
####   1. Client-mode (DEFAULT, no config needed): variables below already
####      point at the hosted gateway. Just connect a wallet via the
####      dashboard at /tokagent-billing/v1/billing/dashboard/.
####   2. Server-mode (advanced): you want to run your OWN billing-server
####      with your own Postgres + operator wallet. Comment out the two
####      TOKAGENT_GATEWAY_* lines below + uncomment the BILLING_* block.
####      The setup wizard at /v1/billing/setup-panel walks you through it.
#########################################

# Client-mode is on by default. The CLI forwards every billing route to the
# hosted gateway — no local Postgres, no operator key, no chain RPC needed.
BILLING_MODE=client
TOKAGENT_GATEWAY_URL=https://billing-service-production-a8e7.up.railway.app
# TOKAGENT_GATEWAY_TIMEOUT_MS=30000  # default 30s; bump for slow connections

# Paste your minted API key here (from the billing dashboard "Keys" tab) to
# enable the agent's chat composer. With BILLING_CHAT_KEY + the gateway URL
# above, the runtime auto-wires OPENAI_API_KEY / OPENAI_BASE_URL so
# plugin-openai routes inference through the billing rail — every billed
# call debits PTON from your on-chain balance.
# Mint a key at: <TOKAGENT_GATEWAY_URL>/v1/billing/dashboard/  (Keys tab)
# BILLING_CHAT_KEY=sk-ai-...

# ─────────────────────────────────────────────────────────────────────
# ADVANCED — self-host the billing rail
# ─────────────────────────────────────────────────────────────────────
# To run your own billing-server instead of using the hosted gateway:
#   1. Comment out the two TOKAGENT_GATEWAY_* lines above
#   2. Set BILLING_MODE=server (or just unset it — server is the runtime
#      default when no client config is present)
#   3. Uncomment + fill in the BILLING_* vars below
# OR: run the setup wizard at /v1/billing/setup-panel which writes these
# for you and auto-restarts the plugin.
# BILLING_MODE=server
# BILLING_ENABLED=true
# BILLING_AUTH_REQUIRED=true

# Your own Postgres. Any Postgres 14+ works. Quickest local setup:
#   docker run -d --name tokagent-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
#   BILLING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Or use any managed Postgres (Supabase, Railway, AWS RDS, your own server).
# The schema migrations run automatically on first boot.
# BILLING_DATABASE_URL=

# Generate with: openssl rand -hex 32
# WARNING: Do not commit. Used for JWT signing + sk-ai-* HMAC.
# BILLING_AUTH_SECRET=

# WARNING: Do not commit. EOA that calls vault.consumeCredits() on-chain.
# Generate: cast wallet new
# Fund with ~0.1 ETH for gas. Grant OPERATOR_ROLE on ClaudeVault before
# first settlement. Anvil default (test only):
#   0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# BILLING_OPERATOR_PRIVATE_KEY=

# Live mainnet contract addresses (immutable in v1):
# BILLING_VAULT_ADDRESS=0x1072f70e7c490E460fA72AC4171F7aDD1ef2d79F
# BILLING_PTON_ADDRESS=0x00D1EDcE8E7c617891FF76224DFf501c568f1Ce0
# BILLING_CHAIN_ID=1

# Mainnet RPCs.
# CHAIN_RPC_URL is used for vault writes; MAINNET_RPC_URL for TWAP reads.
# Same provider URL is fine. Free public endpoints work for low volume:
#   https://eth.llamarpc.com  |  https://rpc.ankr.com/eth  |  https://ethereum.publicnode.com
# Production: get an Alchemy or Infura API key for higher rate limits.
# BILLING_CHAIN_RPC_URL=
# BILLING_MAINNET_RPC_URL=

# LiteLLM upstream (this is the inference provider the server proxies to).
# Default points at Tokamak's hosted LiteLLM.
# BILLING_LITELLM_BASE_URL=https://api.ai.tokamak.network/
# BILLING_LITELLM_API_KEY=

# Operator margin policy (basis points). Defaults are sensible.
# BILLING_MARGIN_BPS=100
# BILLING_MARGIN_FLOOR_BPS=50
# BILLING_PROMOTION_DISCOUNT_BPS=0

# Rate limits, session TTLs, consume worker cadence — all have sane defaults.
# See packages/billing/src/config.ts for the full env reference.
# BILLING_AUTH_SESSION_TTL_MS=86400000
# BILLING_AUTH_LOGIN_NONCE_TTL_MS=300000
# BILLING_RATE_LIMIT_ENABLED=true
# BILLING_RATE_LIMIT_QUOTE_PER_MIN=60
# BILLING_RATE_LIMIT_SETTLE_PER_MIN=30
# BILLING_FIXED_TON_USD=    # incident-only override for TWAP outage

# (Client-mode is now configured at the top of this section — the
# TOKAGENT_GATEWAY_URL there points at the Tokamak-hosted gateway by
# default. To point at a different operator's server, change that URL.)
