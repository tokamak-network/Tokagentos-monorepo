{
  "name": "@tokagent/plugin-tokagent-yield",
  "version": "0.1.0",
  "description": "elizaOS plugin: deposit and withdraw from Aave v3 on Polygon via the Tokagent vault",
  "type": "module",
  "publishConfig": { "access": "public" },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "lint": "bunx @biomejs/biome check --write .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@tokagentos/core": "workspace:*"
  },
  "dependencies": {
    "@tokagent/plugin-tokagent-shared": "workspace:*",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tokagentos/core": "workspace:*",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
