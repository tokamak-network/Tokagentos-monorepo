{
  "name": "@elizaos/capacitor-camera",
  "version": "1.0.0",
  "description": "Captures photos, records video, and streams camera preview with manual controls.",
  "keywords": [
    "camera",
    "capture",
    "media",
    "vision"
  ],
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "ios/Plugin.xcodeproj/",
    "electrobun/",
    "*.podspec"
  ],
  "author": "elizaOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza"
  },
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.0.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "capacitor": {
    "ios": {
      "src": "ios",
      "podName": "ElizaCapacitorCamera"
    },
    "android": {
      "src": "android"
    }
  },
  "elizaos": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Full support via MediaDevices API (camera preview, photo/video capture, permissions)",
      "node": "Full support via Electrobun native modules with macOS/Windows/Linux camera access",
      "ios": true,
      "android": true
    }
  }
}
