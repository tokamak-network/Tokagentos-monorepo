{
  "name": "@elizaos/capacitor-swabble",
  "version": "1.0.0",
  "description": "Detects wake words and transcribes live speech with microphone state events.",
  "keywords": [
    "voice",
    "wake-word",
    "speech-to-text",
    "microphone"
  ],
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "ios/Plugin.xcodeproj/",
    "electrobun/",
    "*.podspec"
  ],
  "author": "elizaOS",
  "license": "MIT",
  "dependencies": {
    "@elizaos/app-core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza"
  },
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.0.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "capacitor": {
    "ios": {
      "src": "ios",
      "podName": "ElizaCapacitorSwabble"
    },
    "android": {
      "src": "android"
    }
  },
  "elizaos": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Support via Web Speech API (limited timing data, no Whisper). Wake word detection and basic STT.",
      "node": "Full support via Electrobun with Whisper.cpp for high-quality STT and precise timing data",
      "ios": true,
      "android": true
    }
  }
}
