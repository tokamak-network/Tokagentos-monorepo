{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "bun", "react", "react-dom"],
    "typeRoots": [
      "./node_modules/@types",
      "../app-core/node_modules/@types",
      "../ui/node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types"
    ],
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@tokagentos/core": ["../typescript/src/index.node.ts"],
      "@tokagentos/core/*": ["../typescript/src/*"],
      "@elizaos/native-activity-tracker": [
        "../native-plugins/activity-tracker/src/index.ts"
      ],
      "@tokagentos/app-lifeops": ["../../apps/app-lifeops/src/index.ts"],
      "@tokagentos/app-lifeops/*": ["../../apps/app-lifeops/src/*"],
      "@tokagentos/app-tokagentmaker": ["../../apps/app-tokagentmaker/src/index.ts"],
      "@tokagentos/app-tokagentmaker/*": ["../../apps/app-tokagentmaker/src/*"],
      "@tokagentos/app-form": ["../../apps/app-form/src/index.ts"],
      "@tokagentos/app-form/*": ["../../apps/app-form/src/*"],
      "@tokagentos/app-core": ["../app-core/src/index.ts"],
      "@tokagentos/app-core/*": ["../app-core/src/*"],
      "@tokagentos/app-steward": ["../../apps/app-steward/src/index.ts"],
      "@tokagentos/app-steward/*": ["../../apps/app-steward/src/*"],
      "@tokagentos/app-shopify": ["../../apps/app-shopify/src/index.ts"],
      "@tokagentos/app-shopify/*": ["../../apps/app-shopify/src/*"],
      "@tokagentos/app-vincent": ["../../apps/app-vincent/src/index.ts"],
      "@tokagentos/app-vincent/*": ["../../apps/app-vincent/src/*"],
      "@tokagentos/ui": ["../ui/src/index.ts"],
      "@tokagentos/ui/*": ["../ui/src/*"],
      "@tokagentos/app-companion": ["../../apps/app-companion/src/index.ts"],
      "@tokagentos/app-companion/*": ["../../apps/app-companion/src/*"],
      "@tokagentos/app-knowledge": ["../../apps/app-knowledge/src/index.ts"],
      "@tokagentos/app-knowledge/*": ["../../apps/app-knowledge/src/*"],
      "@tokagentos/app-training": ["../../apps/app-training/src/index.ts"],
      "@tokagentos/app-training/*": ["../../apps/app-training/src/*"],
      "@tokagentos/agent": ["./src/index.ts"],
      "@tokagentos/agent/*": ["./src/*"],
      "@tokagentos/shared": ["../shared/src/index.ts"],
      "@tokagentos/shared/*": ["../shared/src/*"],
      "@tokagentos/skills": ["../skills/src/index.ts"],
      "@tokagentos/skills/*": ["../skills/src/*"],
      "react": ["../app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": ["../app-core/node_modules/@types/react-dom/index.d.ts"],
      "@elizaos/*": ["../../node_modules/@elizaos/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/__tests__/**"
  ]
}
