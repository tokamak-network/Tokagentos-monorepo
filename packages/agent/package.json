{
  "name": "@elizaos/agent",
  "version": "2.0.0-alpha.223",
  "description": "Standalone elizaOS-based agent and backend server package.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaos/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza.git",
    "directory": "packages/agent"
  },
  "keywords": [
    "eliza",
    "agent",
    "backend",
    "runtime",
    "elizaos"
  ],
  "main": "src/index.ts",
  "bin": {
    "eliza-autonomous": "./src/bin.ts"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run build:dist",
    "build:docker-dist": "rm -rf dist && tsc --noCheck -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/agent --compiled-prefix=packages/agent/src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/agent --compiled-prefix=packages/agent/src",
    "lint": "bunx @biomejs/biome check ./src/actions ./src/api ./src/auth ./src/awareness ./src/bin.ts ./src/cli ./src/cloud ./src/config ./src/contracts ./src/diagnostics ./src/hooks ./src/index.ts ./src/onboarding-presets.ts ./src/plugins ./src/providers ./src/runtime ./src/security ./src/server ./src/services ./src/shared ./src/testing ./src/triggers ./src/utils ./src/version-resolver.ts",
    "lint:check": "bun run lint",
    "lint:fix": "bunx @biomejs/biome check --write ./src/actions ./src/api ./src/auth ./src/awareness ./src/bin.ts ./src/cli ./src/cloud ./src/config ./src/contracts ./src/diagnostics ./src/hooks ./src/index.ts ./src/onboarding-presets.ts ./src/plugins ./src/providers ./src/runtime ./src/security ./src/server ./src/services ./src/shared ./src/testing ./src/triggers ./src/utils ./src/version-resolver.ts",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "training:cli": "bun run src/training/cli.ts",
    "pack:dry-run": "cd dist && npm pack --dry-run",
    "test": "vitest run --config vitest.config.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./actions": "./src/actions/index.ts",
    "./actions/*": "./src/actions/*.ts",
    "./api": "./src/api/index.ts",
    "./api/*": "./src/api/*.ts",
    "./api/server": "./src/api/server.ts",
    "./api/server-auth": "./src/api/server-auth.ts",
    "./auth": "./src/auth/index.ts",
    "./auth/*": "./src/auth/*.ts",
    "./autonomy": "./src/autonomy/index.ts",
    "./autonomy/*": "./src/autonomy/*.ts",
    "./awareness": "./src/awareness/index.ts",
    "./awareness/*": "./src/awareness/*.ts",
    "./cli": "./src/cli/index.ts",
    "./cli/*": "./src/cli/*.ts",
    "./cloud": "./src/cloud/index.ts",
