    "./cloud/base-url": "./src/cloud/base-url.ts",
    "./cloud/validate-url": "./src/cloud/validate-url.ts",
    "./cloud/cloud-manager": "./src/cloud/cloud-manager.ts",
    "./config": "./src/config/index.ts",
