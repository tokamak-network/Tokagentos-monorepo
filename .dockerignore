# Reduce build context: build artifacts, env secrets, and largest dirs
.git
**/node_modules
**/.turbo
**/dist
**/target
**/venv
**/.venv
**/*.so
**/*.wasm
**/.tokagent
**/.tokagentdb
**/*.log
**/.env
**/.env.*
.DS_Store
.github
.cursor
# Large dirs (keep all packages/ and plugins/ so workspace resolves)
examples
# Exclude most apps/*. Re-include the ones packages/agent + packages/app-core
# statically import (they crash with "Cannot find module" otherwise).
apps/*
# Only app-companion is committed to git in this repo — the others (lifeops,
# vincent, knowledge, steward, training, shopify, tokagentmaker, task-
# coordinator) were intentionally removed in commit 59868695. Re-includes
# below would do nothing for them and the Dockerfile now only copies
# app-companion. See apps/billing-server/Dockerfile for the rationale.
!apps/app-companion
!apps/app-companion/**
tokagent-cloud-v2
**/fonts
**/*.otf
**/*.ttf
**/*.woff2
